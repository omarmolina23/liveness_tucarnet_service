# Copia este archivo como .env y completa los valores.

# ===== Servidor =====
PORT=4000

# ===== AWS =====
# Región donde están Rekognition y el bucket S3 (ej. us-east-1)
AWS_REGION=

# Bucket S3 donde se almacenan las fotos del liveness
S3_BUCKET=

# ARN del rol que STS asume para generar credenciales temporales de la sesión de liveness
AWS_LIVENESS_ROLE_ARN=

# Credenciales AWS (el SDK las toma de la cadena por defecto).
# ⚠️ NUNCA subas estos valores a git.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Segundos de validez de las URLs firmadas de S3 (opcional, default 600)
SIGNED_URL_EXPIRATION=600
